{
  "name": "claude-code-workspace-hodovani",
  "displayName": "Claude Code Workspace (Hodovani fork)",
  "description": "Fork of andrewmkhoury.claude-code-workspace with shared-secret HTTP auth (VSCODE_BRIDGE_TOKEN) and the upstream double-shebang/icon-path bugs fixed.",
  "version": "0.11.0",
  "publisher": "hodovani",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/hodovani/vscode-claude-code-bridge"
  },
  "bugs": {
    "url": "https://github.com/hodovani/vscode-claude-code-bridge/issues"
  },
  "homepage": "https://github.com/hodovani/vscode-claude-code-bridge#readme",
  "icon": "resources",
  "galleryBanner": {
    "color": "#1e1e2e",
    "theme": "dark"
  },
  "categories": ["AI", "Other"],
  "keywords": ["claude", "claude-code", "mcp", "ai", "copilot", "workspace"],
  "engines": {
    "vscode": "^1.90.0"
  },
  "activationEvents": ["onStartupFinished"],
  "main": "./dist/extension.js",
  "contributes": {
    "configuration": {
      "title": "Claude Code Workspace",
      "properties": {
        "claudeCodeWorkspace.claudePath": {
          "type": "string",
          "default": "",
          "markdownDescription": "Path to the `claude` CLI binary. Leave empty to auto-detect from `$PATH` and common install locations (e.g. `~/.local/bin/claude`)."
        },
        "claudeCodeWorkspace.port": {
          "type": "number",
          "default": 29837,
          "minimum": 1024,
          "maximum": 65535,
          "description": "Local HTTP port the bridge server listens on. Must match the port configured in the MCP server."
        },
        "claudeCodeWorkspace.maxSymbols": {
          "type": "number",
          "default": 100,
          "minimum": 1,
          "maximum": 500,
          "description": "Maximum number of symbols returned by a workspace symbol search."
        },
        "claudeCodeWorkspace.maxFiles": {
          "type": "number",
          "default": 200,
          "minimum": 1,
          "maximum": 1000,
          "description": "Maximum number of files returned by a file search."
        },
        "claudeCodeWorkspace.maxSearchResults": {
          "type": "number",
          "default": 100,
          "minimum": 1,
          "maximum": 500,
          "description": "Maximum number of results returned by a text search."
        },
        "claudeCodeWorkspace.maxReferences": {
          "type": "number",
          "default": 200,
          "minimum": 1,
          "maximum": 500,
          "description": "Maximum number of reference locations returned per find-references call."
        }
      }
    },
    "commands": [
      {
        "command": "claudeCodeWorkspace.configure",
        "title": "Claude Code Workspace: Configure Claude Code",
        "shortTitle": "Configure Claude Code"
      },
      {
        "command": "claudeCodeWorkspace.unconfigure",
        "title": "Claude Code Workspace: Remove Claude Code Configuration",
        "shortTitle": "Remove Claude Code Configuration"
      }
    ],
    "chatParticipants": [
      {
        "id": "claude-code-workspace.claude",
        "fullName": "Claude Code",
        "name": "claude",
        "description": "Ask Claude Code anything about your workspace",
        "isSticky": true
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run bundle",
    "bundle": "npm run bundle:ext && npm run bundle:mcp",
    "bundle:ext": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --minify",
    "bundle:mcp": "esbuild src/mcp-server.ts --bundle --outfile=dist/mcp-server.mjs --format=esm --platform=node --banner:js='#!/usr/bin/env node' --minify",
    "build": "npm run build:ext && npm run build:mcp",
    "build:ext": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --sourcemap",
    "build:mcp": "esbuild src/mcp-server.ts --bundle --outfile=dist/mcp-server.mjs --format=esm --platform=node --banner:js='#!/usr/bin/env node' --sourcemap",
    "watch": "npm run build -- --watch",
    "typecheck": "tsc --noEmit",
    "package": "vsce package",
    "publish": "vsce publish"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.6.1",
    "zod": "^3.21.4"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.90.0",
    "@vscode/vsce": "^3.0.0",
    "esbuild": "^0.24.0",
    "typescript": "^5.4.0"
  }
}
