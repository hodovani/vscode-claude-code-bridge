{
  "name": "mcp-server-vscode",
  "version": "0.8.0",
  "description": "MCP server that exposes VS Code workspace intelligence (symbols, diagnostics, references, definitions, text search) to Claude Code via the Claude Code Workspace extension.",
  "license": "Apache-2.0",
  "author": "akhoury",
  "repository": {
    "type": "git",
    "url": "https://github.com/andrewmkhoury/vscode-claude-code-bridge",
    "directory": "mcp-server"
  },
  "bugs": {
    "url": "https://github.com/andrewmkhoury/vscode-claude-code-bridge/issues"
  },
  "homepage": "https://github.com/andrewmkhoury/vscode-claude-code-bridge#readme",
  "keywords": ["mcp", "claude", "claude-code", "vscode", "workspace", "lsp"],
  "type": "module",
  "bin": {
    "mcp-server-vscode": "dist/index.js"
  },
  "files": ["dist", "README.md", "LICENSE"],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.6.1",
    "zod": "^3.21.4"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.4.0"
  }
}
